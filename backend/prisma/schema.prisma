generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  ceo
  manager
  employee
}

enum ProjectStatus {
  active
  completed
  on_hold
}

enum ReviewStatus {
  pending
  approved
  rejected
  needs_changes
}

enum ReviewPriority {
  low
  medium
  high
  critical
}

enum SprintStatus {
  planned
  active
  completed
}

enum TaskIssueType {
  story
  task
  bug
  epic
}

enum TaskStatus {
  backlog
  todo
  in_progress
  in_review
  blocked
  done
}

enum TaskPriority {
  low
  medium
  high
  critical
}

model User {
  id               Int              @id @default(autoincrement())
  email            String           @unique
  googleId         String?          @unique @map("google_id")
  hashedPassword   String?          @map("hashed_password")
  fullName         String?          @map("full_name")
  role             UserRole         @default(employee)
  department       String?
  isActive         Boolean          @default(true) @map("is_active")
  ownedProjects    Project[]        @relation("ProjectOwner")
  submittedReviews ReviewRequest[]  @relation("ReviewSubmitter")
  reviewedReviews  ReviewRequest[]  @relation("ReviewReviewer")
  authoredReviewComments ReviewComment[] @relation("ReviewCommentAuthor")
  sentDirectMessages     DirectMessage[]  @relation("DirectMessageSender")
  receivedDirectMessages DirectMessage[]  @relation("DirectMessageRecipient")
  memberships      ProjectMember[]
  assignedTasks    Task[]           @relation("TaskAssignee")
  createdTasks     Task[]           @relation("TaskCreator")
  authoredTaskComments TaskComment[] @relation("TaskCommentAuthor")
  reports          DailyProgressReport[] @relation("ReportSubmitter")
  onboardingToken  String?               @unique @map("onboarding_token")
  resetPasswordToken String?             @unique @map("reset_password_token")
  resetPasswordTokenExpiresAt DateTime?   @map("reset_password_token_expires_at")

  @@index([fullName])
  @@map("users")
}

model Project {
  id           Int              @id @default(autoincrement())
  name         String
  description  String?
  department   String?
  status       ProjectStatus    @default(active)
  ownerId      Int?             @map("owner_id")
  owner        User?            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  memberships  ProjectMember[]
  reviews      ReviewRequest[]
  tasks        Task[]
  sprints      Sprint[]
  reports      DailyProgressReport[]
  createdAt    DateTime?        @default(now()) @map("created_at")
  updatedAt    DateTime?        @updatedAt @map("updated_at")

  @@index([name])
  @@map("projects")
}

model ProjectMember {
  projectId Int @map("project_id")
  userId    Int @map("user_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_members")
}

model ReviewRequest {
  id                 Int             @id @default(autoincrement())
  title              String
  summary            String?
  objective          String?
  status             ReviewStatus    @default(pending)
  priority           ReviewPriority   @default(medium)
  reviewType         String?         @map("review_type")
  websiteUrl         String?         @map("website_url")
  githubRepo         String?         @map("github_repo")
  figmaLink          String?         @map("figma_link")
  documentationLink  String?         @map("documentation_link")
  techDetails        Json?           @map("tech_details")
  projectId          Int?            @map("project_id")
  project            Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  submitterId        Int?            @map("submitter_id")
  submitter          User?           @relation("ReviewSubmitter", fields: [submitterId], references: [id], onDelete: SetNull)
  reviewerId         Int?            @map("reviewer_id")
  reviewer           User?           @relation("ReviewReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewComments     ReviewComment[]
  attachments        ReviewAttachment[]
  createdAt          DateTime?       @default(now()) @map("created_at")
  updatedAt          DateTime?       @updatedAt @map("updated_at")

  @@index([title])
  @@map("review_requests")
}

model ReviewComment {
  id              Int            @id @default(autoincrement())
  content         String
  reviewRequestId Int?           @map("review_request_id")
  reviewRequest    ReviewRequest? @relation(fields: [reviewRequestId], references: [id], onDelete: Cascade)
  authorId        Int?           @map("author_id")
  author          User?          @relation("ReviewCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt       DateTime?      @default(now()) @map("created_at")

  @@index([reviewRequestId, createdAt, id])
  @@map("review_comments")
}

model ReviewAttachment {
  id              Int            @id @default(autoincrement())
  reviewRequestId Int            @map("review_request_id")
  reviewRequest   ReviewRequest  @relation(fields: [reviewRequestId], references: [id], onDelete: Cascade)
  fileName        String         @map("file_name")
  mimeType        String         @map("mime_type")
  sizeBytes       Int            @map("size_bytes")
  data            Bytes
  createdAt       DateTime?      @default(now()) @map("created_at")

  @@index([reviewRequestId])
  @@map("review_attachments")
}

model Sprint {
  id          Int          @id @default(autoincrement())
  name        String
  goal        String?
  status      SprintStatus @default(planned)
  startDate   DateTime?    @db.Date @map("start_date")
  endDate     DateTime?    @db.Date @map("end_date")
  projectId   Int          @map("project_id")
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime?    @default(now()) @map("created_at")
  updatedAt   DateTime?    @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([status])
  @@map("sprints")
}

model DirectMessage {
  id          Int       @id @default(autoincrement())
  content     String
  senderId    Int       @map("sender_id")
  sender      User      @relation("DirectMessageSender", fields: [senderId], references: [id])
  recipientId Int       @map("recipient_id")
  recipient   User      @relation("DirectMessageRecipient", fields: [recipientId], references: [id])
  isRead      Boolean   @default(false) @map("is_read")
  createdAt   DateTime? @default(now()) @map("created_at")

  @@index([senderId, recipientId, createdAt, id])
  @@index([recipientId, senderId, createdAt, id])
  @@map("direct_messages")
}

model Task {
  id           Int          @id @default(autoincrement())
  title        String
  description  String?
  issueType    TaskIssueType @default(task) @map("issue_type")
  status       TaskStatus   @default(todo)
  priority     TaskPriority @default(medium)
  projectId    Int          @map("project_id")
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprintId     Int?         @map("sprint_id")
  sprint       Sprint?      @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  assigneeId   Int?         @map("assignee_id")
  assignee     User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creatorId    Int          @map("creator_id")
  creator      User         @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  dueDate      DateTime?    @db.Date @map("due_date")
  estimateMinutes Int?      @map("estimate_minutes")
  loggedMinutes   Int       @default(0) @map("logged_minutes")
  comments     TaskComment[]
  reportLinks  DailyProgressReportTask[]
  createdAt    DateTime?    @default(now()) @map("created_at")
  updatedAt    DateTime?    @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([sprintId])
  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}

model TaskComment {
  id        Int       @id @default(autoincrement())
  content   String
  taskId    Int       @map("task_id")
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  Int?      @map("author_id")
  author    User?     @relation("TaskCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime? @default(now()) @map("created_at")

  @@index([taskId])
  @@map("task_comments")
}

model DailyProgressReport {
  id           Int       @id @default(autoincrement())
  content      String
  yesterday    String?
  today        String?
  blockers     String?
  minutesSpent Int?      @map("minutes_spent")
  date         DateTime  @db.Date
  submitterId  Int       @map("submitter_id")
  submitter    User      @relation("ReportSubmitter", fields: [submitterId], references: [id], onDelete: Cascade)
  projectId    Int?      @map("project_id")
  project      Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  taskLinks    DailyProgressReportTask[]
  attachments  ReportAttachment[]
  createdAt    DateTime? @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  @@index([submitterId])
  @@index([projectId])
  @@index([date])
  @@map("daily_progress_reports")
}

model DailyProgressReportTask {
  reportId Int @map("report_id")
  taskId   Int @map("task_id")
  report   DailyProgressReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  task     Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([reportId, taskId])
  @@map("daily_progress_report_tasks")
}

model ReportAttachment {
  id          Int                 @id @default(autoincrement())
  reportId    Int                 @map("report_id")
  report      DailyProgressReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  fileName    String              @map("file_name")
  mimeType    String              @map("mime_type")
  sizeBytes   Int                 @map("size_bytes")
  data        Bytes
  createdAt   DateTime?           @default(now()) @map("created_at")

  @@index([reportId])
  @@map("report_attachments")
}
