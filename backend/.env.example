# Copy to backend/.env and adjust for your environment.
# These override the defaults in app/core/config.py.

# IMPORTANT: set a strong random value in any shared/production environment.
SECRET_KEY=change-me-to-a-long-random-string

# Token lifetime in minutes (default: 8 days)
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Postgres settings (only used if you switch off the local SQLite default)
POSTGRES_SERVER=localhost
POSTGRES_USER=erh_user
POSTGRES_PASSWORD=erh_password
POSTGRES_DB=erh_db
